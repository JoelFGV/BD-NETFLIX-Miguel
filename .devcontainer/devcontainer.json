{
  "name": "Netflix - Docker Compose com APP",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/postgresql:1": {}
  },

  "containerEnv": {
    "PGUSER": "postgres",
    "PGPASSWORD": "mysecretpassword",
    "PGDATABASE": "netflix",
    "PGHOST": "db"
  }
}
